# Copy this file to .env.local and fill in the values.
# Everything here is OPTIONAL — the app runs without any of it (offline scoring,
# local-only progress, no login). Add keys to unlock the full experience.

# --- AI grading (server-side only, never exposed to the browser) ---
# Used by /api/check/score, /api/check/coach, /api/check/question, /api/check/followup.
# Without it, the app falls back to a local heuristic scorer.
OPENAI_API_KEY=sk-...

# --- User accounts + cross-device sync (Supabase, magic-link auth) ---
# Safe to expose: the anon key is protected by Row Level Security (see supabase/schema.sql).
# Get both from your Supabase project: Settings → API.
# Without these, the app runs local-only with no sign-in.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
